# Activamos el motor de reescritura de URLs
RewriteEngine On

# Si la petición es un archivo real (CSS, JS, imágenes, video), lo servimos directo.
# Esto evita que el Router intente manejar los assets estáticos.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Todo lo demás lo redirigimos al punto de entrada de la aplicación (app/index.php).
# $1 captura todo lo que hay en la URL y lo pasa como parámetro ?url=
# QSA (Query String Append) preserva otros parámetros GET que puedan existir.
RewriteRule ^(.*)$ app/index.php?url=$1 [QSA,L]
